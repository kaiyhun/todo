# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# tooling scratch output (Playwright MCP snapshots / console logs)
/.playwright-mcp/

# playwright e2e artifacts
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but DO commit the example template (no secrets)
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
