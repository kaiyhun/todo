# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values. `.env.local` is
# gitignored and must never be committed.
# ---------------------------------------------------------------------------

# MongoDB connection string.
#   • Hosted: MongoDB Atlas (free M0 tier works) → mongodb+srv://user:pass@cluster/...
#   • Local:  a local install / Docker           → mongodb://127.0.0.1:27017
MONGODB_URI="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?appName=todo"

# Logical database name the app reads/writes. Use a dev-specific name locally so
# development never touches production data.
MONGODB_DB="todo_dev"

# Secret used by Auth.js to sign session JWTs.
# Generate one with:  npx auth secret     (or)   openssl rand -base64 33
AUTH_SECRET="replace-me-with-a-long-random-string"

# Set to "true" to disable authentication entirely and run as a single local
# user (offline / self-hosted "just run it" mode). Leave "false" for hosted use.
LOCAL_MODE=false
